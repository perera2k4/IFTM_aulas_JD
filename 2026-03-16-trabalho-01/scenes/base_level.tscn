[sub_resource type="GDScript" id="GDScript_0pxoi"]
script/source = "extends Node2D

@onready var hud: CanvasLayer = $HUD
@onready var player: CharacterBody2D = $Player
@onready var mark_die: Marker2D = $MarkDie

var start_position

func _ready() -> void :
	start_position = player.global_position
	
	# Conectando com o sinal - fruit_collected
	var all_fruits = get_tree().get_nodes_in_group(\"g_fruits\")
	for fruit in all_fruits:
		fruit.fruit_collected.connect(_on_fruit_collected)
	
	# Conectando com o sinal - damaged
	var all_damages = get_tree().get_nodes_in_group(\"g_damages\")
	for damage in all_damages:
		damage.damaged.connect(_on_damaged)
	
	# Conectando com o sinal - checkpoint_is_picked
	var all_checkpoints = get_tree().get_nodes_in_group(\"g_checkpoint\")
	for cp in all_checkpoints:
		cp.checkpoint_is_picked.connect(_on_checkpoint_picked)
	
func _process(delta: float) -> void:
	# Verifica se caiu do mapa
	if player.global_position.y > mark_die.global_position.y:
		_on_damaged()
		
# Detecta colisão com o checkpoint
func _on_checkpoint_picked():
	hud.update_checkpoint_status()
	GlobalIterates.has_checkpoint = true
	await get_tree().create_timer(2).timeout
	player.global_position.y = -375
	player.global_position.x = 2250

# Detecta colisão e soma +1 fruta no hud
func _on_fruit_collected():
	hud.eat_fruit()

# Detecta dano/morte do player
func _on_damaged():
	hud.death_count()
	
	# Verifica na variável global se ele pegou o checkpoint
	if GlobalIterates.has_checkpoint:
		get_tree().change_scene_to_file(\"res://scenes/levels/level_2.tscn\")
	else:
		get_tree().change_scene_to_file(\"res://scenes/levels/level_1.tscn\")
"

